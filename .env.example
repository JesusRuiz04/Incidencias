# Configuración del Sistema de Incidencias de Tráfico
# Copiar este archivo a .env y ajustar valores según sea necesario

# Seguridad
SECRET_KEY=tu-clave-secreta-super-segura-cambiar-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Base de Datos
DATABASE_URL=sqlite:///data/incidencias.db

# Upload de Archivos
UPLOAD_FOLDER=static/uploads
MAX_UPLOAD_SIZE=5242880  # 5MB en bytes

# API
API_HOST=127.0.0.1
API_PORT=8000

# Modo Debug
DEBUG=True
